# Copy to .env and fill in. .env is gitignored — never commit real secrets.
# See README.md for what each value means and how to obtain the Google/Turnstile/SMTP keys.

# --- Database (the compose db service uses these too) ---
DB_NAME=calit
DB_USER=calit
DB_PASSWORD=change-me-strong-db-password

# --- App ---
# Host port to expose the app on (container always listens on 8080).
APP_PORT=8080
# No admin password here: on first run the app redirects to /setup to create the first user
# (a site admin). More users are managed in-app at /me/users, or enable SIGNUP_ENABLED.
# Public origin users hit; also the base for invitee manage links + the Google OAuth redirect.
APP_BASE_URL=https://book.example.com

# --- SMTP (required for outbound email) ---
MAIL_HOST=smtp.example.com
MAIL_USERNAME=postmaster@example.com
MAIL_PASSWORD=change-me-smtp-password
MAIL_FROM=calit@example.com

# Choose ONE encryption mode to match your provider's port. The port does NOT pick the
# mode automatically, so set all three values together.

# Option A — port 587, STARTTLS (most common; connection starts plaintext, upgrades to TLS).
MAIL_PORT=587
MAIL_START_TLS=REQUIRED
MAIL_TLS=false

# Option B — port 465, implicit TLS / SMTPS (encrypted from the first byte).
# Comment out Option A above and uncomment these:
# MAIL_PORT=465
# MAIL_TLS=true
# MAIL_START_TLS=OPTIONAL

# --- Behaviour (optional; defaults shown) ---
REMINDER_LEAD_MINUTES=1440
APPROVAL_HOLD_HOURS=24
# Scheduler grace window (seconds): reminder + pending-expiry ticks treat a row as due up to this
# many seconds early, so replicas on independent timers fire on time instead of a tick late. Default 30, 0 = exact.
SCHEDULER_GRACE_SECONDS=30
PER_EMAIL_DAILY_CAP=10

# --- Google Calendar sync (optional; leave blank to run in degraded mode) ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Redirect URIs are OPTIONAL — they default to ${APP_BASE_URL}/api/google/callback and
# ${APP_BASE_URL}/api/google/login/callback. Uncomment to override only for unusual proxy paths.
# Either way, register BOTH derived URLs as authorized redirect URIs in your Google OAuth client.
#GOOGLE_OAUTH_REDIRECT_URI=https://book.example.com/api/google/callback
#GOOGLE_OAUTH_LOGIN_REDIRECT_URI=https://book.example.com/api/google/login/callback
# Strong random string shared by all replicas, e.g. `openssl rand -hex 32`.
GOOGLE_OAUTH_STATE_SECRET=
# How often each connected Google account is probed for a still-valid connection (and the cadence
# of the "reconnect your Google" email). Duration string. Default 1h. Lower = faster detection,
# more Google API calls; higher = slower detection.
GOOGLE_PROBE_INTERVAL=1h

# --- Public site / Google verification (optional) -----------------------------
# Google Search Console domain-verification token. When set, every page renders
# <meta name="google-site-verification">. Leave blank to verify via DNS TXT instead.
GOOGLE_SITE_VERIFICATION=
# Shown as the data controller on /privacy and /terms. Defaults to APP_BASE_URL if blank.
OPERATOR_NAME=
# Contact address shown on /privacy for data/privacy requests. Hidden if blank.
PRIVACY_CONTACT_EMAIL=

# Signs/encrypts the login session cookie (>=16 chars). Must be the same on every replica.
# Generate: openssl rand -hex 32
SESSION_ENCRYPTION_KEY=

# AES-256-GCM key for Google OAuth tokens at rest. 64 hex chars (openssl rand -hex 32).
# Required in prod. Must be the same on every replica; keep it stable (rotating strands ciphertext).
TOKEN_ENCRYPTION_KEY=

# --- Cloudflare Turnstile (optional; one switch drives widget + server verification) ---
TURNSTILE_ENABLED=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
